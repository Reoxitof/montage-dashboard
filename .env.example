# Ces variables d'environnement surchargent config.json
# Utilisez-les sur Sliplane pour configurer sans modifier config.json

# Serveur
SERVER_PORT=8080
PUBLIC_URL=https://your-app.sliplane.app

# Auth session (OBLIGATOIRE - changez cette valeur !)
SESSION_SECRET=CHANGE_ME_ULTRA_SECURE_SESSION_SECRET
OWNER_USERNAME=your_twitch_username

# Twitch
TWITCH_CHANNEL=your_twitch_channel
TWITCH_OAUTH=oauth:your_oauth_token
TWITCH_CLIENT_ID=
TWITCH_BROADCASTER_ID=

# OBS Bridge (si vous utilisez obs-local-bridge)
OBS_BRIDGE_URL=http://your-bridge-host:3001
OBS_BRIDGE_TOKEN=CHANGE_ME_BRIDGE_TOKEN
